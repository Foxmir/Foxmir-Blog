document.querySelector(\".home-content-layer\");\n  const band = document.querySelector(\".home-band\");\n  const sticky = document.querySelector(\".home-band-sticky\");\n  const track = document.querySelector(\".home-band-track\");\n  const panels = Array.from(document.querySelectorAll(\".home-band-panel\"));\n  let ticking = false;\n  let cycleHeight = 1;\n  let ringCycles = 1;\n\n  function setGeometry(){\n    const vh = window.innerHeight;\n    // 鍔ㄦ€佽绠?Latest section 搴旇闇插嚭鐨勯珮搴︼紙1.5琛岋級\n    const latest = document.querySelector(\".home-latest-section\");\n    if(cl && latest){\n      const firstTitle = latest.querySelector(\".listing-title, .listing-title a, h3\");\n      let lineHeight = 24;\n      if(firstTitle){\n        const titleStyle = window.getComputedStyle(firstTitle);\n        const lh = parseFloat(titleStyle.lineHeight);\n        if(!isNaN(lh)){\n          lineHeight = lh;\n        } else {\n          const fs = parseFloat(titleStyle.fontSize);\n          if(!isNaN(fs)) lineHeight = fs * 1.2;\n        }\n      }\n      const exposedHeight = Math.ceil(lineHeight * 1.5);\n      const desiredTop = vh - exposedHeight;\n      const currentTop = latest.getBoundingClientRect().top;\n      const currentMargin = parseFloat(window.getComputedStyle(cl).marginTop) || 0;\n      const calibratedMargin = Math.max(0, Math.round(currentMargin - (currentTop - desiredTop)));\n      document.documentElement.style.setProperty(\"--content-layer-margin-top\", `${calibratedMargin}px`);\n    }\n    if(!band||!sticky||!track||!panels.length)return;\n    if(window.innerWidth<=640){\n      sticky.style.height=\"\";\n      band.style.height=\"\";\n      panels.forEach(p=>p.style.minHeight=\"\");\n      return;\n    }\n    const ph = Math.max(...panels.map(p=>p.scrollHeight),300);\n    const stickyH = Math.min(ph, Math.floor(vh*0.72));\n    sticky.style.height = stickyH+\"px\";\n    panels.forEach(p=>p.style.minHeight=stickyH+\"px\");\n    const dist = Math.max(track.scrollWidth - sticky.clientWidth, 0);\n    cycleHeight = dist>0 ? Math.max(vh*0.58, stickyH*0.52) : 1;\n    ringCycles = dist>0 ? Math.max(panels.length + 2, 5) : 1;\n    const scrollRange = cycleHeight * ringCycles;\n    band.style.height = (stickyH + scrollRange)+\"px\";\n  }\n\n  function draw(){\n    const y = window.scrollY;\n    const fade = Math.min(y/380,1);\n    if(title){\n      title.style.transform=`translate3d(0,${y*0.16}px,0)`;\n      title.style.filter=`blur(${fade*16}px) grayscale(${fade*100}%)`;\n      title.style.opacity=Math.max(1-fade*1.6,0);\n    }\n    if(stageIntro){\n      stageIntro.style.transform=`translate3d(0,${y*0.16}px,0)`;\n      stageIntro.style.filter=`blur(${fade*10}px) grayscale(${fade*90}%)`;\n      stageIntro.style.opacity=Math.max(1-fade*1.5,0);\n    }\n    if(!band||!sticky||!track||!panels.length||window.innerWidth<=640)return;\n    const stickyTop = parseFloat(getComputedStyle(sticky).top)||0;\n    const start = band.offsetTop - stickyTop;\n    const span = Math.max(cycleHeight * ringCycles, 1);\n    const local = Math.min(Math.max(window.scrollY - start,0),span);\n    const phase = ((local / Math.max(cycleHeight,1)) % 1 + 1) % 1;\n    const dist = Math.max(track.scrollWidth - sticky.clientWidth, 0);\n    track.style.transform=`translate3d(${-phase*dist}px,0,0)`;\n  }\n\n  window.addEventListener(\"scroll\",function(){\n    if(!ticking){requestAnimationFrame(function(){draw();ticking=false;});ticking=true;}\n  },{passive:true});\n\n  window.addEventListener(\"resize\",function(){setGeometry();draw();});\n  setGeometry(); draw();\n})()\n</script>\n```\n"},"formats":{"html":{"identifier":{"display-name":"HTML","target-format":"html","base-format":"html"},"execute":{"fig-width":7,"fig-height":5,"fig-format":"retina","fig-dpi":96,"df-print":"default","error":false,"eval":true,"cache":null,"freeze":false,"echo":true,"output":true,"warning":true,"include":true,"keep-md":false,"keep-ipynb":false,"ipynb":null,"enabled":null,"daemon":null,"dae